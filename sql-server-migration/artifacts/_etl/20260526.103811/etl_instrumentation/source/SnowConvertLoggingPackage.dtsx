          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using System.Data;
using Microsoft.SqlServer.Dts.Runtime;
using System.Windows.Forms;
using System.Xml;
using System.Data.OleDb;
using System.IO;
using System.Collections.Generic;
#endregion

namespace ST_0dfc01d4a71d407193827ea3b277de81
{
    /// <summary>
    /// ScriptMain is the entry point class of the script.  Do not change the name, attributes,
    /// or parent of this class.
    /// </summary>
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {

        #region Configuration file loading and processing
        private class TableToMonitor
        {
            public readonly string Name;
            public readonly string Database;
            public readonly string Schema;
            public readonly string ConnectionString;
            public TableToMonitor(string name, string database, string schema, string connectionString)
            {
                this.Name = name;
                this.Database = database;
                this.Schema = schema;
                this.ConnectionString = connectionString;
            }
        }
        private string ResolveConnectionString(XmlElement tableElement, string tableName)
        {
            string connectionString = null;
            var connectionManager = tableElement.GetAttribute("ConnectionManagerId");
            var tableConnectionString = tableElement.GetAttribute("ConnectionString");
            if (!string.IsNullOrEmpty(connectionManager) && Dts.Connections.Contains(connectionManager))
            {
                connectionString = Dts.Connections[connectionManager].ConnectionString;
                var overrideVariable = tableElement.GetAttribute("VariableWithPassword");
                if (!string.IsNullOrEmpty(overrideVariable) && Dts.Variables.Contains(overrideVariable))
                {
                    var psw = Dts.Variables[overrideVariable].GetSensitiveValue();
                    connectionString = connectionString + ";password=" + psw;
                }
                else
                {
                    Dts.Events.FireWarning(0, "SnowConvert instrumentation", "[SnowConvertInstrumentation] Cannot find variable to override password for:" + tableName, "", 0);
                }
            }
            else if (!string.IsNullOrEmpty(tableConnectionString))
            {
                connectionString = tableConnectionString;
            }
            else
            {
                Dts.Events.FireError(0, "SnowConvert instrumentation", "[SnowConvertInstrumentation] Connection information not specified for :" + tableName, "", 0);
            }
            return connectionString;
        }
        private void InitializeTableInfo(string configurationPath,out Dictionary<string, List<TableToMonitor>> tableInfo, out Dictionary<string, string> taskNameVsGuid)
        {
            ConfigFileInfo fileInfo;
            if (configInfo.TryGetValue(configurationPath, out fileInfo))
            {
                tableInfo = fileInfo.tableInfo;
                taskNameVsGuid = fileInfo.taskNameVsGuid;
                return;
            }
            tableInfo = new Dictionary<string, List<TableToMonitor>>(StringComparer.InvariantCultureIgnoreCase);
            taskNameVsGuid = new Dictionary<string, string>(StringComparer.InvariantCultureIgnoreCase);
            var confDoc = new XmlDocument();
            confDoc.Load(configurationPath);
            var overridenConnectionStrings = new Dictionary<string, string>();
            foreach (XmlElement connectionStringInfoElement in confDoc.DocumentElement.GetElementsByTagName("ConnectionString"))
            {
                var connectionManagerId = connectionStringInfoElement.GetAttribute("Id");
                var connectionString = connectionStringInfoElement.InnerText;
                if (!string.IsNullOrEmpty(connectionManagerId) && !string.IsNullOrEmpty(connectionString))
                {
                    overridenConnectionStrings[connectionManagerId] = connectionString;
                }
            }
            foreach (XmlElement taskConfig in confDoc.DocumentElement.GetElementsByTagName("TaskConfig"))
            {
                var guid = taskConfig.GetAttribute("TaskGuid");
                var taskName = taskConfig.GetAttribute("TaskName");
                taskNameVsGuid[taskName] = guid;

                var tables = new List<TableToMonitor>();
                tableInfo[guid] = tables;
                foreach (XmlElement table in taskConfig.GetElementsByTagName("TableToMonitor"))
                {
                    var tableName = table.GetAttribute("Name");
                    var schemaName = table.GetAttribute("Schema");
                    var databaseName = table.GetAttribute("Database");
                    var connectionManagerId = table.GetAttribute("ConnectionManagerId");
                    string overridenConnectionString;
                    var connectionString =
                        !string.IsNullOrEmpty(connectionManagerId) && overridenConnectionStrings.TryGetValue(connectionManagerId, out overridenConnectionString)
                        ? overridenConnectionString
                        : this.ResolveConnectionString(table, tableName);
                    tables.Add(new TableToMonitor(tableName, databaseName, schemaName, connectionString));
                }
            }
        }

        private static Dictionary<string, ConfigFileInfo> configInfo = new Dictionary<string, ConfigFileInfo>();
        class ConfigFileInfo { 
            public Dictionary<string, List<TableToMonitor>> tableInfo = null;
            public Dictionary<string, string> taskNameVsGuid = null;
        }
        #endregion

        const string LogDirectoryVarName = "$Package::SnowConvertLogsDirectory";
        const string SourceExecutableVarName = "$Package::CurrentExecutable";
        const string SourceExecutableIdVarName = "$Package::CurrentExecutableId";
        const string SourcePackageVarName = "$Package::SourcePackageName";
        const string StartTimeVarName = "System::StartTime";

        #region Intialization
        private string[] requiredVariables = new[] {
            LogDirectoryVarName,
            SourceExecutableVarName,
            SourceExecutableIdVarName,
            SourcePackageVarName,
            StartTimeVarName
        };
        private bool CheckMandatoryVariables()
        {
            foreach (var variable in requiredVariables)
            {
                if (!Dts.Variables.Contains(variable))
                {
                    Dts.Events.FireError(14, "SnowConvert instrumentation", "[SnowConvertInstrumentation] Required variable not provided: " + variable, "", 0);
                    return false;
                }
            }
            return true;
        }

        private static void InitLogFileIfRequired(string logFileName)
        {
            var directory = System.IO.Path.GetDirectoryName(logFileName);
            Directory.CreateDirectory(directory);
            if (!File.Exists(logFileName))
            {
                File.WriteAllText(logFileName, "TaskName,Guid,SchemaName,TableName,RowCount\n");
            }
        }
        #endregion

        /// <summary>
        /// This method is called when this script task executes in the control flow.
        /// Before returning from this method, set the value of Dts.TaskResult to indicate success or failure.
        /// To open Help, press F1.
        /// </summary>
        public void Main()
        {
            bool raiseAgain = false;
            try
            {
                if (CheckMandatoryVariables())
                {                    
                    var directoriesVariable = (string)Dts.Variables[LogDirectoryVarName].Value;
                    var sourceId = (string)Dts.Variables[SourceExecutableIdVarName].Value;
                    var sourceName = (string)Dts.Variables[SourceExecutableVarName].Value;
                    var packageName = (string)Dts.Variables[SourcePackageVarName].Value;
                  //  var startTime = (DateTime)Dts.Variables[StartTimeVarName].Value;
                    var resultSimpleFileName = packageName /*+ startTime.ToString("yyyyMMdd_hhmm")*/ + "_control_flow_results.csv";
                    var configurationPath = System.IO.Path.Combine(directoriesVariable, packageName + "_control_flow_configuration.xml");

                    if (System.IO.File.Exists(configurationPath))
                    {

                        Dictionary<string, List<TableToMonitor>> tableInfo;
                        Dictionary<string, string> taskNameVsGuid;
                         InitializeTableInfo(configurationPath, out tableInfo, out taskNameVsGuid);
                        
                        var logFileName = System.IO.Path.Combine(directoriesVariable, resultSimpleFileName);
                        List<TableToMonitor> tables;
                        string alternativeGuid;
                        Dts.Events.FireInformation(0, "SnowConvert instrumentation", "[SnowConvertInstrumentation] config sourceId = " + sourceId, "", 0, ref raiseAgain);
                        if (tableInfo.TryGetValue(sourceId, out tables)
                            || (taskNameVsGuid.TryGetValue(sourceName, out alternativeGuid)
                                && tableInfo.TryGetValue(alternativeGuid, out tables)))
                        {
                            foreach (var tableToMonitor in tables)
                            {
                                var tableName = tableToMonitor.Name;
                                var schemaName = tableToMonitor.Schema;
                                var connectionString = tableToMonitor.ConnectionString;

                                ProcessTableToMonitor(sourceName, sourceId, tableToMonitor, logFileName);
                            }
                        }
                        else
                        {
                            Dts.Events.FireInformation(0, "SnowConvert instrumentation", "[SnowConvertInstrumentation] No tables to monitor for Id = " + sourceId + " name=" + sourceName, "", 0, ref raiseAgain);
                        }
                    }
                    else
                    {
                        Dts.Events.FireError(14, "SnowConvert instrumentation", "[SnowConvertInstrumentation] Logging configuration file not found: " + configurationPath, "", 0);
                    }
                }
                else
                {
                    Dts.Events.FireError(14, "SnowConvert instrumentation", "[SnowConvertInstrumentation] Required variables not specified", "", 0);
                }
                Dts.TaskResult = (int)ScriptResults.Success;
            }
            catch (Exception e)
            {
                Dts.Events.FireError(14, "SnowConvert instrumentation", "[SnowConvertInstrumentation] Exception running post task handler: " + e.ToString(), "", 0);
            }
        }



        private void ProcessTableToMonitor(string taskName, string taskId, TableToMonitor table, string logFileName)
        {
            try
            {
                using (var connection = new System.Data.OleDb.OleDbConnection(table.ConnectionString))
                {
                    connection.Open();
                    var schemaName = SanitizeTableName(table.Schema);
                    var tableName = SanitizeTableName(table.Name);
                    using (var command = new OleDbCommand())
                    {
                        command.Connection = connection;
                        command.CommandType = CommandType.Text;
                        command.CommandText = "SELECT COUNT(*) FROM " + schemaName + "." + tableName;
                        var result = Convert.ToInt32(command.ExecuteScalar());
                        var lineToLog = string.Format("{0},{1},{2},{3},{4},{5}\n", taskName, taskId, schemaName, tableName, result, DateTime.Now);
                        InitLogFileIfRequired(logFileName);
                        System.IO.File.AppendAllText(logFileName, lineToLog);
                    }
                    connection.Close();
                }
            }
            catch (Exception e)
            {
                Dts.Events.FireError(1, "SnowConvert instrumentation", "[SnowConvertInstrumentation] Exception collecting data for table: " + table.Name + ", error: " + e.ToString(), "", 0);
            }
        }

        private static string SanitizeTableName(string name)
        {
            if (!(name.StartsWith("[") && name.EndsWith("]")))
            {
                return "[" + name.Replace("[", "[[").Replace("]", "]]") + "]";
            }
            return name;
        }



        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

    }
}]]></ProjectItem>
